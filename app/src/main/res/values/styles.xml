<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Estilo para ítems de guía -->
    <style name="GuideItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#475569</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <!-- Tema general de la app -->
    <style name="Theme.App" parent="Theme.Material3.Light.NoActionBar">
        <item name="materialCalendarTheme">@style/ThemeOverlay.App.DatePicker</item>
        <item name="textInputStyle">@style/CustomTextInputLayout</item> <!-- Aplicar estilo global a los inputs -->
        <item name="editTextStyle">@style/CustomEditText</item>
    </style>

    <!-- Estilo para el calendario -->
    <style name="ThemeOverlay.App.DatePicker" parent="@style/ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/white_smoke</item>
        <item name="colorOnPrimary">@color/white_smoke</item>
        <item name="shapeCornerFamily">cut</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
    </style>

    <!-- Estilo base del TextInputLayout del calendario -->
    <style name="Widget.App.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/black</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <!-- Estilo personalizado para los campos de texto (Inputs) -->
    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">#2E4053</item> <!-- Azul marino -->
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="android:textColorHint">#2E4053</item>
        <item name="hintTextColor">#2E4053</item>
    </style>

    <!-- Estilo para los TextInputEditText -->
    <style name="CustomEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:textColor">#2E4053</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Tema overlay por si quieres aplicar los estilos como overlay en fragmentos específicos -->
    <style name="ThemeOverlay.App.TextFields" parent="ThemeOverlay.Material3.TextInputEditText">
        <item name="textInputStyle">@style/CustomTextInputLayout</item>
        <item name="editTextStyle">@style/CustomEditText</item>
    </style>

</resources>
