<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_home">

    <fragment
        android:id="@+id/nav_home"
        android:name="com.torrezpillcokevin.nuna.ui.inicio.HomeFragment"
        android:label="Inicio"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/nav_chatbot"
        android:name="com.torrezpillcokevin.nuna.ui.chatbot.ChatBotFragment"
        android:label="Chatbot"
        tools:layout="@layout/fragment_chat_bot" />

    <fragment
        android:id="@+id/nav_guia"
        android:name="com.torrezpillcokevin.nuna.GuiaFragment"
        android:label="Guía"
        tools:layout="@layout/fragment_guia" />

    <fragment
        android:id="@+id/nav_soporte"
        android:name="com.torrezpillcokevin.nuna.ui.soporte.SoporteFragment"
        android:label="Soporte"
        tools:layout="@layout/fragment_soporte" />

    <fragment
        android:id="@+id/nav_preguntasfrecuentes"
        android:name="com.torrezpillcokevin.nuna.ui.preguntasfrecuentes.PreguntasFrecuentesFragment"
        android:label="Preguntas Frecuentes"
        tools:layout="@layout/fragment_preguntas_frecuentes" />

    <fragment
        android:id="@+id/nav_contactoEmergencia"
        android:name="com.torrezpillcokevin.nuna.ui.contactosEmergencia.ContactoEmergenciaFragment"
        android:label="ContactoEmergencia"
        tools:layout="@layout/fragment_contacto_emergencia" />

    <fragment
        android:id="@+id/nav_muro"
        android:name="com.torrezpillcokevin.nuna.ui.muro.MuroFragment"
        android:label="Muro Desaparecidos"
        tools:layout="@layout/fragment_muro">
        <action
            android:id="@+id/action_nav_muro_to_nav_DesaparecidoFragment"
            app:destination="@id/nav_DesaparecidoFragment" />
    </fragment>

    <fragment
        android:id="@+id/nav_DesaparecidoFragment"
        android:name="com.torrezpillcokevin.nuna.ui.reportar_desaparecido.ReportarDesaparecidoFragment"
        android:label="Reportar Desaparecido"
        tools:layout="@layout/fragment_reportar_desaparecido" />

    <!-- ✅ Activity Evaluación — ID único -->
    <activity
        android:id="@+id/nav_evaluacion"
        android:name="com.torrezpillcokevin.nuna.EvaluacionActivity"
        android:label="Evaluación de Riesgo"
        tools:layout="@layout/activity_evaluacion" />

    <!-- ✅ Activity Red Jurídica — ID CAMBIADO a nav_red_juridica -->
    <activity
        android:id="@+id/nav_red_juridica"
        android:name="com.torrezpillcokevin.nuna.PoliticaActivity"
        android:label="Red Jurídica"
        tools:layout="@layout/activity_politica" />

    <!-- ✅ Fragment Términos y Condiciones -->
    <fragment
        android:id="@+id/nav_terminos"
        android:name="com.torrezpillcokevin.nuna.ui.terminos.TerminosFragment"
        android:label="Términos y Condiciones"
        tools:layout="@layout/fragment_terminos" />

    <!-- ✅ Fragment Política de Privacidad — ID único, no duplicado -->
    <fragment
        android:id="@+id/nav_politica"
        android:name="com.torrezpillcokevin.nuna.ui.politica.PoliticaFragment"
        android:label="Política de Privacidad"
        tools:layout="@layout/fragment_politica" />

</navigation>