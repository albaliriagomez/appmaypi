<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".ui.contactosEmergencia.ContactoEmergenciaFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título principal -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MIS CONTACTOS DE EMERGENCIA"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Código del usuario -->
        <TextView
            android:id="@+id/codeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CODIGOPERSONA54525"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Instrucciones -->
        <TextView
            android:id="@+id/instructionsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agrega tu Contacto de Emergencia para notificarle en caso de apretar el botón de Pánico. \n\nAl agregar o modificar un contacto se le enviará tu código de persona. Si solo está la persona en tu lista de contactos con tu código al reportar la denuncia a las autoridades podrá ubicarte."
            android:textColor="#757575"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Formulario de entrada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/nameEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Nombre"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:elevation="2dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/phoneEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Teléfono"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:elevation="2dp"
                android:layout_marginEnd="8dp" />

            <Spinner
                android:id="@+id/spinner_linea_telefonica"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:padding="8dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/spinner_background" />
        </LinearLayout>

        <!-- Botón de agregar contacto -->
        <Button
            android:id="@+id/addContactButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar Contacto"
            android:backgroundTint="#FFC107"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Tabla de contactos -->
        <TableLayout
            android:id="@+id/contactTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1"
            android:background="#F9F9F9"
            android:elevation="2dp">

            <!-- Encabezados -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFC107">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nombre"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Teléfono"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Línea Telefónica"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acciones"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />
            </TableRow>

        </TableLayout>
    </LinearLayout>
</ScrollView>