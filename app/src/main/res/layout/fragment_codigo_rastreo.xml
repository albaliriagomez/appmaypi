<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".ui.codigoRastreo.CodigoRastreoFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Título principal -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CÓDIGO DE RASTREO"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Código del usuario -->
        <TextView
            android:id="@+id/codeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CODIGOPERSONA54525"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Instrucciones -->
        <TextView
            android:id="@+id/instructionsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aquí puedes ver y gestionar tus códigos de rastreo. \n\nAl agregar o modificar un código, asegúrate de que la información sea correcta para un seguimiento preciso."
            android:textColor="#757575"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Formulario de entrada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/codeEditText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:hint="Código"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:elevation="2dp"
                android:layout_marginEnd="8dp" />

            <AutoCompleteTextView
                android:id="@+id/autoCompleteStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Estado"
                android:padding="12dp"
                android:background="#F5F5F5"
                android:elevation="2dp" />
        </LinearLayout>

        <!-- Botón de agregar código -->
        <Button
            android:id="@+id/addCodeButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Agregar Código"
            android:backgroundTint="#6200EE"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Tabla de códigos -->
        <TableLayout
            android:id="@+id/codeTable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1"
            android:background="#F9F9F9"
            android:elevation="2dp">

            <!-- Encabezados -->
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#6200EE">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="Código"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estado"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acciones"
                    android:textColor="#FFFFFF"
                    android:padding="8dp"
                    android:textStyle="bold" />
            </TableRow>

        </TableLayout>
    </LinearLayout>
</ScrollView>