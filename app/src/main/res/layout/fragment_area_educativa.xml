<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.areaEducativa.AreaEducativaFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Primera fila: Videos Educativos -->
        <TextView
            android:id="@+id/textViewVideos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Videos Educativos"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/videosLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Ejemplo de un video -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/baseline_personal_video_24"
                        android:contentDescription="asdasdasda" /> <!-- Agrega descripción para accesibilidad -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción del Curso" />
                </LinearLayout>

                <!-- Agrega más LinearLayouts para otros videos aquí -->

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Segunda fila: Infografía -->
        <TextView
            android:id="@+id/textViewInfografia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Infografía"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            android:layout_marginTop="16dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/infografiaLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Ejemplo de una infografía -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/baseline_personal_video_24"
                        android:contentDescription="asdasdasd" /> <!-- Agrega descripción para accesibilidad -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción de la Infografía" />
                </LinearLayout>

                <!-- Agrega más LinearLayouts para otras infografías aquí -->

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

</FrameLayout>
