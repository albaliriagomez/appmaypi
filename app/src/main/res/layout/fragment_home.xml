<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ui.inicio.HomeFragment">

    <!-- Logo con CardView y elevación como en main -->
    <androidx.cardview.widget.CardView
        android:id="@+id/logoCardView"
        android:layout_width="90dp"
        android:layout_height="90dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="45dp"
        app:cardElevation="12dp">

        <ImageView
            android:id="@+id/logoImageView"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:padding="12dp"
            android:contentDescription="Logo"
            android:src="@drawable/ic_logo" />
    </androidx.cardview.widget.CardView>

    <!-- Botones de íconos con el estilo del main -->
    <LinearLayout
        android:id="@+id/iconButtonsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/logoCardView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón Teléfono -->
        <androidx.cardview.widget.CardView
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="31dp"
            app:cardElevation="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Círculo de fondo con gradiente sutil -->
                <View
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:alpha="0.1"
                    android:background="@drawable/circle_gradient_light" />

                <ImageView
                    android:id="@+id/phoneIcono"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    android:padding="2dp"
                    android:contentDescription="Phone Icon"
                    android:src="@drawable/telefono_icono" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón Cámara -->
        <androidx.cardview.widget.CardView
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="31dp"
            app:cardElevation="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Círculo de fondo con gradiente sutil -->
                <View
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:alpha="0.1"
                    android:background="@drawable/circle_gradient_camera" />

                <ImageView
                    android:id="@+id/camaraIcono"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    android:padding="2dp"
                    android:contentDescription="Camera Icon"
                    android:src="@drawable/cam_icono" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón Micrófono -->
        <androidx.cardview.widget.CardView
            android:layout_width="62dp"
            android:layout_height="62dp"
            android:layout_marginEnd="18dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="31dp"
            app:cardElevation="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Círculo de fondo con gradiente sutil -->
                <View
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:alpha="0.1"
                    android:background="@drawable/circle_gradient_mic" />

                <ImageView
                    android:id="@+id/microphoneIcono"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    android:padding="2dp"
                    android:contentDescription="Microphone Icon"
                    android:src="@drawable/mic_icono" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón Mensaje -->
        <androidx.cardview.widget.CardView
            android:layout_width="62dp"
            android:layout_height="62dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="31dp"
            app:cardElevation="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Círculo de fondo con gradiente sutil -->
                <View
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:alpha="0.1"
                    android:background="@drawable/circle_gradient_message" />

                <ImageView
                    android:id="@+id/messageIcono"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless"
                    android:padding="2dp"
                    android:contentDescription="Message Icon"
                    android:src="@drawable/mensj_icono" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Texto de instrucción -->
    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/iconButtonsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="En caso de emergencia presiona el Botón"
        android:textColor="#34495E"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_regular"/>

    <!-- Botón rojo central con el estilo del main -->
    <androidx.cardview.widget.CardView
        android:id="@+id/redButtonCard"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/instructionText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="75dp"
        app:cardElevation="16dp">

        <!-- Container para el botón con múltiples capas -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="1dp">

            <!-- Capa base - Gradiente rojo -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/red_button_gradient" />

            <!-- Capa de brillo superior -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:layout_gravity="top"
                android:alpha="0.6"
                android:scaleType="centerCrop"
                android:src="@drawable/button_shine" />

            <!-- Botón interactivo -->
            <ImageView
                android:id="@+id/redButton"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Red Button" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Descripción del botón rojo -->
    <TextView
        android:id="@+id/redButtonDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/redButtonCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="Al presionar el botón se enviará un mensaje a tus contactos de emergencia con tu ubicación, se sacará una foto, se grabará un audio de 15 seg y se llamará a tu contacto de emergencia."
        android:textColor="#34495E"
        android:textSize="14sp"
        android:gravity="center"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_regular"/>

</androidx.constraintlayout.widget.ConstraintLayout>