<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:mapbox="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.reportar.ReportarFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F7F7F7">

            <!-- Título -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFC107"
                android:text="DESAPARECIDO"
                android:textSize="26sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:padding="8dp" />

            <!-- Información y foto -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:weightSum="3">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2">

                    <TextView
                        android:id="@+id/textName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nathaniel L. Heady"
                        android:textStyle="bold"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/textDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edad: 36 | Altura: 1.83 cm | Peso: 77 kg\nCabello: Rubio"
                        android:layout_marginTop="4dp"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/lastLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Última Ubicación:\n4593 High Meadow Lane Hanover, MD 21076"
                        android:layout_marginTop="8dp"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Descripción -->
            <TextView
                android:id="@+id/descriptionField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fue visto por última vez el 24 de noviembre de 2023..."
                android:padding="8dp"
                android:textSize="14sp"
                android:background="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <!-- Campos del formulario -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="REPORTAR INFORMACIÓN DEL DESAPARECIDO"
                android:textStyle="bold"
                android:textSize="18sp"
                android:padding="8dp" />

            <EditText
                android:id="@+id/nameField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre (opcional)"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/emailField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email (opcional)"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/phoneField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Teléfono (opcional)"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/consentCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consentimiento para Contactar"
                android:layout_marginBottom="16dp" />


            <!-- Campo de Fecha y Hora -->
            <EditText
                android:id="@+id/dateField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Fecha y Hora del Avistamiento"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Campo de Ubicación -->
            <EditText
                android:id="@+id/locationField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ubicación del Avistamiento"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Mapa -->
            <com.mapbox.maps.MapView
                android:id="@+id/mapContainer"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="16dp" />

            <!-- Campo Descripción -->
            <EditText
                android:id="@+id/observationDescriptionField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Descripción de la persona o acción observada"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Campo para Subir Imagen -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Imagen del Suceso (Opcional)"
                    android:textSize="16sp"
                    android:layout_marginBottom="4dp" />

                <Button
                    android:id="@+id/uploadImageButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cargar Imagen"
                    android:backgroundTint="#FFC107"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Botones -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="2">

                <Button
                    android:id="@+id/clearButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Limpiar"
                    android:backgroundTint="#B3B3B3"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/sendButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Enviar"
                    android:backgroundTint="#FFC107"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
