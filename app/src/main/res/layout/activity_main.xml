<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- Logo -->

    <ImageView
        android:id="@+id/logoImageView"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_logo" />

    <!-- ImageView para mostrar la foto capturada -->
    <ImageView
        android:id="@+id/imageViewCaptura"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:contentDescription="Foto Capturada"
        android:scaleType="centerCrop" />


    <!-- Botones de íconos -->
    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:gravity="center">



        <ImageView
            android:id="@+id/phoneIcono"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/telefono_icono" />

        <ImageView
            android:id="@+id/camaraIcono"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:src="@drawable/cam_icono" />

        <ImageView
            android:id="@+id/microphoneIcono"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:src="@drawable/mic_icono" />

        <ImageView
            android:id="@+id/messageIcono"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="20dp"
            android:src="@drawable/mensj_icono" />
    </LinearLayout>

    <!-- Botón rojo central -->
    <ImageView
        android:id="@+id/redButton"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:src="@drawable/rojo_boton" />

    <!-- Formulario para agregar contactos -->
    <TextView
        android:id="@+id/addContactLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Agrega tu Contacto de Emergencia para notificarle"
        android:layout_marginTop="16dp"
        android:textColor="#000000"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="3">

        <EditText
            android:id="@+id/nameEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nombre"
            android:background="#E0E0E0"
            android:padding="8dp" />

        <EditText
            android:id="@+id/phoneEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Teléfono"
            android:background="#E0E0E0"
            android:padding="8dp"
            android:inputType="phone" />

        <EditText
            android:id="@+id/lineEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Línea Telefónica"
            android:background="#E0E0E0"
            android:padding="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/addContactButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Agregar Contacto"
        android:backgroundTint="#6200EE"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp" />

    <!-- Lista de contactos -->
    <ListView
        android:id="@+id/contactListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />

    <!-- Botones de Ingresar y Registrarse -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/loginButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ingresar"
            android:backgroundTint="#6200EE"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/registerButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Registrarse"
            android:backgroundTint="#03DAC5"
            android:textColor="#FFFFFF" />
    </LinearLayout>





</LinearLayout>



