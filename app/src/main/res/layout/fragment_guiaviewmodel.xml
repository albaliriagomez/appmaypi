<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.guia.GuiaViewModel">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8FAFC"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Botón de retroceso -->
            <TextView
                android:id="@+id/backToGettingStarted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back to Getting Started"
                android:textColor="#4F46E5"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- Título principal -->
            <TextView
                android:id="@+id/whatIsThisAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="What is this app?"
                android:textColor="#1E293B"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Texto introductorio -->
            <TextView
                android:id="@+id/introText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt"
                android:textColor="#64748B"
                android:textSize="16sp"
                android:layout_marginBottom="16dp" />

            <!-- Encabezado Nivel 2 -->
            <TextView
                android:id="@+id/headerLevel2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Header Level 2"
                android:textColor="#1E293B"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Párrafo -->
            <TextView
                android:id="@+id/paragraph1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pellentesque habitant morbi tristique senectus et netus et malesuada fames ac turpis egestas. Vestibulum tortor quam, feugiat vitae, ultricies eget, tempor sit amet, ante. Donec eu libero sit amet quam egestas semper."
                android:textColor="#475569"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/paragraph2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Orci varius natoque penatibus et magnis dis parturient montes, nascetur ridiculus mus. Class aptent taciti sociosqu ad litora torquent per conubia nostra, per inceptos himenaeos."
                android:textColor="#475569"
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Texto destacado -->
            <TextView
                android:id="@+id/highlightedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suspendisse ullamcorper nunc non pellentesque laoreet."
                android:textColor="#F59E0B"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <!-- Encabezado Nivel 3 -->
            <TextView
                android:id="@+id/headerLevel3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Header Level 3"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- Imagen -->
            <ImageView
                android:id="@+id/sampleImage"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp"
                android:scaleType="centerCrop"
                android:src="@drawable/infantes" />

            <!-- Encabezado Nivel 4 -->
            <TextView
                android:id="@+id/headerLevel4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Header Level 4"
                android:textColor="#1E293B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>