<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/transparent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:background="@color/white_smoke"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@color/white_smoke">

            <!-- Título del Diálogo -->
            <TextView
                android:id="@+id/txtTituloDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Detalles de la Persona"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/charcoal"
                android:textAlignment="center"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Contenedor de la imagen (circular) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardImageContainer"
                android:layout_width="120dp"
                android:layout_height="120dp"
                app:cardCornerRadius="60dp"
                app:cardElevation="4dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/txtTituloDialog"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/imgPersonaDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Foto de la persona desaparecida"
                    tools:src="@android:drawable/ic_menu_gallery"/>
            </androidx.cardview.widget.CardView>

            <!-- Nombre de la persona (destacado) -->
            <TextView
                android:id="@+id/txtNombreDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/dark_slate_gray"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardImageContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Juan Pérez"/>

            <!-- Tiempo desaparecido (destacado en amber) -->
            <TextView
                android:id="@+id/txtTiempoDesaparecido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="@color/amber"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/txtNombreDetalle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="2 días desaparecido"/>

            <!-- Card con información básica -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInfoBasica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/txtTiempoDesaparecido"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Información Personal"
                        android:textStyle="bold"
                        android:textColor="@color/charcoal"
                        android:textSize="16sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gainsboro"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtEdadDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_slate_gray"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"
                        tools:text="Edad: 30 años"/>

                    <TextView
                        android:id="@+id/txtGeneroDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_slate_gray"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"
                        tools:text="Género: Masculino"/>

                    <TextView
                        android:id="@+id/txtFechaNacimientoDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_slate_gray"
                        android:textSize="14sp"
                        tools:text="Fecha de nacimiento: 15/05/1994"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card con información sobre la desaparición -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInfoDesaparicion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardInfoBasica"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Detalles de la Desaparición"
                        android:textStyle="bold"
                        android:textColor="@color/amber"
                        android:textSize="16sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gainsboro"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtFechaDesaparicionDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/amber"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"
                        tools:text="Fecha de desaparición: 01/04/2025"/>

                    <TextView
                        android:id="@+id/txtLugarDesaparicionDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_slate_gray"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"
                        tools:text="Lugar de desaparición: Ciudad de México"/>

                    <TextView
                        android:id="@+id/txtDescripcionDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_slate_gray"
                        android:textSize="14sp"
                        tools:text="Descripción: Desapareció en la zona centro."/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card con información adicional -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInfoAdicional"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/cardInfoDesaparicion"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Información Adicional"
                        android:textStyle="bold"
                        android:textColor="@color/olive"
                        android:textSize="16sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gainsboro"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtEstadoInvestigacionDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/amber"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"
                        tools:text="Estado: En investigación"/>

                    <TextView
                        android:id="@+id/txtCaracteristicasDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dark_slate_gray"
                        android:textSize="14sp"
                        tools:text="Características: 1.75m, cabello corto negro, lunar en la mejilla."/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/cardInfoAdicional"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <Button
                    android:id="@+id/btnReportar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reportar Información"
                    android:textColor="@color/white_smoke"
                    android:backgroundTint="@color/olive"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnCerrar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cerrar"
                    android:textColor="@color/white_smoke"
                    android:backgroundTint="@color/charcoal"
                    android:padding="12dp"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>