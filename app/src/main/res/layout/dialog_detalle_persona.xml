<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@android:color/transparent">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:background="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgPersonaDetalle"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:layout_marginBottom="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/txtNombreDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2E4053"
                app:layout_constraintTop_toBottomOf="@id/imgPersonaDetalle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/txtEdadDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#2E4053"
                app:layout_constraintTop_toBottomOf="@id/txtNombreDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtGeneroDetalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#2E4053"
                app:layout_constraintTop_toBottomOf="@id/txtEdadDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtDescripcionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2E4053"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtGeneroDetalle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/txtFechaNacimientoDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2E4053"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtDescripcionDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtFechaDesaparicionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF0000"
                android:textStyle="bold"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtFechaNacimientoDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtLugarDesaparicionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2E4053"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtFechaDesaparicionDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtEstadoInvestigacionDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#808000"
                android:textStyle="bold"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtLugarDesaparicionDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtCaracteristicasDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2E4053"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtEstadoInvestigacionDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtTiempoDesaparecido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#FF0000"
                android:textStyle="bold"
                android:paddingTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtCaracteristicasDetalle"
                app:layout_constraintStart_toStartOf="parent"/>

            <Button
                android:id="@+id/btnCerrar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cerrar"
                android:textColor="#2E4053"
                android:backgroundTint="#FFC107"
                android:padding="12dp"
                app:layout_constraintTop_toBottomOf="@id/txtTiempoDesaparecido"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
