<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEFF1">

    <androidx.cardview.widget.CardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detalles de la Persona"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:textColor="#2E4053"
                    android:layout_marginBottom="8dp"/>

                <ImageView
                    android:id="@+id/imgPersonaDetalle"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_person"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/circle_background"
                    android:padding="8dp"/>

                <TextView
                    android:id="@+id/txtNombreDetalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2E4053"/>

                <TextView
                    android:id="@+id/txtTiempoDesaparecido"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiempo desaparecido"
                    android:textColor="#FFA000"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Información Personal -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Información Personal"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:background="@drawable/section_header_bg"
                    android:padding="8dp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/txtEdadDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edad"
                    android:textColor="#2E4053"/>

                <TextView
                    android:id="@+id/txtGeneroDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Género"
                    android:textColor="#2E4053"/>

                <TextView
                    android:id="@+id/txtFechaNacimientoDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha nacimiento"
                    android:textColor="#2E4053"/>

                <TextView
                    android:id="@+id/txtDescripcionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Descripción"
                    android:textColor="#2E4053"
                    android:layout_marginBottom="8dp"/>

                <!-- Detalles Desaparición -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Detalles de la Desaparición"
                    android:textStyle="bold"
                    android:textColor="#FFA000"
                    android:background="@drawable/section_header_bg"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/txtFechaDesaparicionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha desaparición"
                    android:textColor="#2E4053"/>

                <TextView
                    android:id="@+id/txtLugarDesaparicionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lugar desaparición"
                    android:textColor="#2E4053"
                    android:layout_marginBottom="8dp"/>

                <!-- Información Adicional -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Información Adicional"
                    android:textStyle="bold"
                    android:textColor="#9E9D24"
                    android:background="@drawable/section_header_bg"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/txtEstadoInvestigacionDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Estado investigación"
                    android:textColor="#2E4053"/>

                <TextView
                    android:id="@+id/txtCaracteristicasDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Características"
                    android:textColor="#2E4053"/>

                <Button
                    android:id="@+id/btnCerrar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cerrar"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1976D2"
                    android:layout_marginTop="16dp"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>
