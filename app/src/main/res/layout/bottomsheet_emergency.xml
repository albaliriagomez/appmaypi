<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configurar Contactos de Emergencia"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:textStyle="bold"
        android:paddingBottom="10dp"/>

    <!-- Sección para el Switch con un padding adecuado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp"
        android:minHeight="48dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvBackgroundService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Servicio en segundo plano"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="8dp"/>

        <Switch
            android:id="@+id/switchBackgroundService"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:minWidth="48dp"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- Spinner con padding y accesibilidad mejorada -->
    <TextView
        android:id="@+id/tvCall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞 Seleccionar Contacto para la Llamada"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="10dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:padding="8dp">

        <Spinner
            android:id="@+id/spinnerCallContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_spinner"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tvSMS"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✉️ Seleccionar Contactos para los SMS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingTop="10dp"/>

    <ListView
        android:id="@+id/lvContacts"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp"/>

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar"
        android:backgroundTint="#34495E"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancelar"
        android:backgroundTint="#95A5A6"
        android:textColor="@android:color/white"
        android:layout_marginTop="5dp"/>
</LinearLayout>
