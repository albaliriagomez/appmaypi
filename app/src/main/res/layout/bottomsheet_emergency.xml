<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_bottom_sheet_top_rounded"
    android:padding="20dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configurar Contactos de Emergencia"
        android:textSize="18sp"
        android:textColor="@color/charcoal"
        android:gravity="center"
        android:textStyle="bold"
        android:paddingBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="48dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvBackgroundService"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Servicio en segundo plano"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/charcoal"
            android:paddingStart="8dp"/>

        <Switch
            android:id="@+id/switchBackgroundService"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:minHeight="48dp"
            android:minWidth="48dp"
            android:thumbTint="@color/amber"
            android:trackTint="@color/olive"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvCall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📞 Seleccionar Contacto para la Llamada"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/charcoal"
        android:paddingTop="10dp"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:background="@drawable/bg_spinner"
        android:padding="8dp">

        <Spinner
            android:id="@+id/spinnerCallContact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tvSMS"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✉️ Seleccionar Contactos para los SMS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/charcoal"
        android:paddingTop="10dp"/>

    <ListView
        android:id="@+id/lvContacts"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:divider="@color/charcoal"
        android:dividerHeight="1dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Guardar"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button"
            app:backgroundTint="@color/charcoal"
            android:textColor="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancelar"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/charcoal"
            app:strokeWidth="1dp"
            android:textColor="@color/charcoal" />
    </LinearLayout>

</LinearLayout>
